# Copy this file to .env and fill in your values.
# .env is gitignored — never commit your real credentials.

GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
PLAYER1_USERNAME=your_github_username
PLAYER2_USERNAME=competitor_github_username

# Optional: competitor's own token so their private commits are counted too.
# Ask them to generate one at github.com/settings/tokens (public_repo + read:user).
PLAYER2_TOKEN=
